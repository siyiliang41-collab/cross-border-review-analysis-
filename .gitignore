__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/

# --- Node / 前端 ---
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE ---
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Claude AI（个人工具目录，严禁提交到团队仓库） ---
.claude/

# --- 大数据中间文件 ---
*.crc
spark-warehouse/
metastore_db/
derby.log

# --- 临时文件 ---
*.tmp
*.bak
*.orig
